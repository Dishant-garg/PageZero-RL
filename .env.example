# ═══════════════════════════════════════════════════════════════════
# Database Configuration (Internal to Cluster)
# ═══════════════════════════════════════════════════════════════════
DB_HOST=postgres
DB_PORT=5432
DB_USER=sre
DB_PASSWORD=sre123
DB_NAME=production

# ═══════════════════════════════════════════════════════════════════
# Redis Configuration (Internal to Cluster)
# ═══════════════════════════════════════════════════════════════════
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# ═══════════════════════════════════════════════════════════════════
# Application External Access (For Health Checks)
# ═══════════════════════════════════════════════════════════════════
APP_EXTERNAL_HOST=localhost
APP_EXTERNAL_PORT=5001

# ═══════════════════════════════════════════════════════════════════
# Remote VM Configuration (For SSH Mode)
# ═══════════════════════════════════════════════════════════════════
# Point VM_HOST to your GCP/AWS instance IP.
# Set VM_SSH_KEY to either:
#   1. A local file path (e.g., ~/.ssh/id_rsa)
#   2. The literal private key string with \n for newlines (e.g., "-----BEGIN...\nBASE64...\n...")
VM_HOST=localhost
VM_USER=ubuntu
VM_SSH_KEY=~/.ssh/id_rsa

# ═══════════════════════════════════════════════════════════════════
# Environment / Judge Settings
# ═══════════════════════════════════════════════════════════════════
ENVIRONMENT_PORT=8000
DEBUG=True
GEMINI_API_KEY=your_key_here

# ═══════════════════════════════════════════════════════════════════
# SLA / Difficulty Settings
# ═══════════════════════════════════════════════════════════════════
PZ_REVENUE_RATE=3900.0
PZ_SLA_THRESHOLD=5.0
PZ_MAX_STEPS=15
PZ_INJECT_WAIT=3.0
